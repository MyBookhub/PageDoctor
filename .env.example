# PageDoctor — environment configuration template
#
# Copy to .env and fill in real values:  cp .env.example .env
# .env is gitignored and MUST NOT be committed.
#
# Every REQUIRED key below is validated at startup (pydantic-settings, fail-fast):
# a missing required value crashes the app on boot rather than at first request.
# Optional keys show their default and may be omitted.

# ── Application ──────────────────────────────────────────────────────────
# Environment name: development | production
APP_ENV=development
# Bind address for the internal PM web app (Uvicorn).
APP_HOST=127.0.0.1
APP_PORT=8000
# REQUIRED. Secret used to sign the CSRF token on the review form / sessions.
# Generate one, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(32))"
APP_SECRET_KEY=
# Optional shared-secret gate for the internal PM web app. Leave BOTH blank for
# local dev (auth disabled). Set both when deploying so the app is not openly
# reachable. A thin HTTP Basic seam; Google Workspace SSO is a future change.
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=
# Optional bearer token for the Google Docs add-on findings API
# (GET /docs/{id}/findings). Leave blank for local dev (endpoint open). Set it
# before exposing the backend (e.g. via a tunnel) so the endpoint requires the
# token; the add-on sends it as `Authorization: Bearer <token>`.
ADDON_TOKEN=

# ── Logging ──────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR. Structured logs only; manuscript/finding
# text is NEVER logged regardless of level (CLAUDE.md §9).
LOG_LEVEL=INFO

# ── Database (PostgreSQL, metadata only) ─────────────────────────────────
# REQUIRED. SQLAlchemy 2.0 URL. The store holds run metadata only — never
# manuscript or finding content (CLAUDE.md §9).
# Format: postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=postgresql+psycopg://pagedoctor:changeme@localhost:5432/pagedoctor

# ── Anthropic (LLM) ──────────────────────────────────────────────────────
# REQUIRED. API key for the Anthropic org.
# IMPORTANT: zero-data-retention + no-training must be enabled on this org
# (hard data-protection rule). This is configured on the Anthropic account,
# not here — and it is why Claude Fable 5 is NOT usable (it requires 30-day
# retention). Keep the model on an Opus tier.
ANTHROPIC_API_KEY=
# Optional. Default editorial model (ZDR-compatible).
ANTHROPIC_MODEL=claude-opus-4-8
# Optional. Reasoning effort for analysis passes: low | medium | high | max.
ANTHROPIC_EFFORT=high
# Optional. Per-run token ceiling so a pathological manuscript can't run up an
# unbounded bill; a run that exceeds it stops and is marked INCOMPLETE.
# Leave blank for no ceiling.
PAGEDOCTOR_TOKEN_BUDGET=

# Optional. Set to 1 to enable the live Anthropic tests (real API calls that cost
# tokens and require a zero-data-retention org). Skipped by default so the test
# suite stays free and offline.
PAGEDOCTOR_LIVE_ANTHROPIC=

# ── Google (Docs read + Drive comments) ──────────────────────────────────
# REQUIRED. Path to the Sophie Hoffmann service-account JSON key file.
# The service account is shared as editor on each target doc per run; access
# stays scoped to the single doc, never the whole Drive (CLAUDE.md §8).
GOOGLE_SERVICE_ACCOUNT_FILE=./secrets/sophie-service-account.json
# Optional. The service account's email (the identity comments appear under).
# Usually derivable from the key file; set if you need it explicit.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Optional. Drive folder where the versioned "_lektoriert_vN" review copies land
# (issue #31). The service account needs write access to this folder. Defaults to
# the shared BookHub Lektorat folder; override per environment if needed.
LEKTORAT_FOLDER_ID=1wEMp95LbYq7zBK0-8QfrrEYI1dKqSy9i
