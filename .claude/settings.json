{
  "permissions": {
    "allow": [
      "Bash(npx tsc)",
      "Bash(source /Users/tillmanndurth/coding_projects/PageDoctor/.venv/bin/activate)",
      "Bash(uv run pytest*)",
      "Bash(uv run ruff check*)",
      "Bash(uv run mypy*)",
      "Bash(uv run ruff format --check*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/py_format_type.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/domain_purity.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/data_protection_guard.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/quality_gate.sh\""
          }
        ]
      }
    ]
  }
}
